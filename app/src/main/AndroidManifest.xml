<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />

    <queries>
        <intent>
            <action android:name="android.intent.action.INSERT" />
            <data android:mimeType="vnd.android.cursor.dir/event" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ToDoListsApp">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ToDoListsApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".notifications.ReminderReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.todolists.action.REMINDER" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".notifications.TestAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.todolists.action.TEST_ALARM" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".notifications.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".widget.SimpleListWidgetReceiver"
            android:exported="true"
            android:label="簡易リスト">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/simple_list_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.AllTasksWidgetReceiver"
            android:exported="true"
            android:label="すべてのタスク">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/all_tasks_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.OverdueWidgetReceiver"
            android:exported="true"
            android:label="期限切れ">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/overdue_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.CompletedWidgetReceiver"
            android:exported="true"
            android:label="完了済み">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/completed_widget_info" />
        </receiver>

        <!-- V2 widget infrastructure (RemoteViewsService + toggle receiver). -->
        <service
            android:name=".widget.SimpleListService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />
        <service
            android:name=".widget.AllTasksService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />
        <service
            android:name=".widget.OverdueService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />
        <service
            android:name=".widget.CompletedService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <receiver
            android:name=".widget.ToggleTaskReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.todolists.action.WIDGET_TOGGLE" />
            </intent-filter>
        </receiver>

        <activity
            android:name=".widget.QuickAddActivity"
            android:exported="false"
            android:theme="@style/Theme.QuickAdd"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleTask" />

        <activity
            android:name=".ui.CropImageActivity"
            android:exported="false"
            android:theme="@style/Theme.ToDoListsApp" />
    </application>

</manifest>
